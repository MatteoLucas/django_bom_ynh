#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# SETTINGS
#=================================================
ynh_script_progression "Storing installation settings..."

# Logging:
log_file="/var/log/$app/$app.log"
ynh_app_setting_set --key=log_file --value="$log_file"

# Database (PostgreSQL instead of Redis)
postgresql_db="${app}_db"
postgresql_user="${app}_user"
postgresql_pwd=$(ynh_string_random)

ynh_app_setting_set --key=postgresql_db --value="$postgresql_db"
ynh_app_setting_set --key=postgresql_user --value="$postgresql_user"
ynh_app_setting_set --key=postgresql_pwd --value="$postgresql_pwd"

#=================================================
# CHECK IF THE APP CAN BE INSTALLED WITH THESE ARGS
#=================================================
ynh_script_progression "Validating installation parameters..."

mkdir -p "$install_dir/media" "$install_dir/static"

#=================================================
# SETUP LOG FILE
#=================================================
ynh_script_progression "Setup logging..."

myynh_setup_log_file

# Use logrotate to manage application logfile(s)
ynh_config_add_logrotate "$log_file"

#=================================================
# INSTALL DEPENDENCIES
#=================================================
ynh_script_progression "Installing dependencies..."

ynh_package_install python3 python3-pip python3-venv postgresql libpq-dev

#=================================================
# SETUP DATABASE (POSTGRESQL)
#=================================================
ynh_script_progression "Configuring PostgreSQL database..."

# Create PostgreSQL user and database
sudo -u postgres psql <<EOF
CREATE USER $postgresql_user WITH PASSWORD '$postgresql_pwd';
CREATE DATABASE $postgresql_db OWNER $postgresql_user;
EOF

#=================================================
# SETUP PYTHON VIRTUALENV AND INSTALL DJANGO-BOM
#=================================================
ynh_script_progression "Setting up Python virtual environment..."

python3 -m venv "$install_dir/venv"
source "$install_dir/venv/bin/activate"
pip install --upgrade pip setuptools wheel
pip install gunicorn psycopg2 django
pip install git+https://github.com/mpkasp/django-bom.git

#=================================================
# CONFIGURE DJANGO-BOM
#=================================================
ynh_script_progression "Configuring Django-Bom..."

# Copy Django settings and config
ynh_config_add --template="settings.py" --destination="$install_dir/settings.py"
ynh_config_add --template="wsgi.py" --destination="$install_dir/wsgi.py"

# Migrate database
cd "$install_dir" || exit
source venv/bin/activate
python manage.py migrate --no-input

# Create superuser
admin_email="$(ynh_user_get_info --username="$admin" --key=mail)"
python manage.py createsuperuser --noinput --username="$admin" --email="$admin_email"

# Collect static files
python manage.py collectstatic --no-input

#=================================================
# CONFIGURE SYSTEMD SERVICE FOR GUNICORN
#=================================================
ynh_script_progression "Configuring systemd service..."

cat > /etc/systemd/system/$app.service <<EOF
[Unit]
Description=Django-Bom Gunicorn
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=$install_dir
ExecStart=$install_dir/venv/bin/gunicorn --workers 3 --bind unix:$install_dir/gunicorn.sock django_bom.wsgi:application

[Install]
WantedBy=multi-user.target
EOF

# Enable and start the service
systemctl enable $app
systemctl start $app

#=================================================
# CONFIGURE NGINX
#=================================================
ynh_script_progression "Configuring nginx web server..."

cat > "/etc/nginx/conf.d/$domain.d/$app.conf" <<EOF
server {
    listen 80;
    server_name $domain;

    location / {
        proxy_pass http://unix:$install_dir/gunicorn.sock;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
    }
}
EOF

# Restart nginx
systemctl reload nginx

#=================================================
# SETUP YUNOHOST SERVICE
#=================================================
ynh_script_progression "Integrating service in YunoHost..."

yunohost service add --description "Django-Bom" $app

#=================================================
# SECURE FILES AND DIRECTORIES
#=================================================
ynh_script_progression "Set $app file permissions..."
myynh_fix_file_permissions

#=================================================
# FINALIZE INSTALLATION
#=================================================
ynh_script_progression "Installation of $app completed"
