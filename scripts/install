#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================
source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# PARAMÈTRES D'INSTALLATION
#=================================================
ynh_script_progression --message="Storing installation settings..."

# Définition des variables essentielles
log_file="/var/log/$app/$app.log"
postgresql_db="${app//-/_}_db"  # Remplace "-" par "_"
postgresql_user="${app//-/_}_user"
postgresql_pwd=$(ynh_string_random)

# Enregistrer les paramètres
ynh_app_setting_set --app=$app --key=log_file --value="$log_file"
ynh_app_setting_set --app=$app --key=postgresql_db --value="$postgresql_db"
ynh_app_setting_set --app=$app --key=postgresql_user --value="$postgresql_user"
ynh_app_setting_set --app=$app --key=postgresql_pwd --value="$postgresql_pwd"

#=================================================
# VALIDATION DES PARAMÈTRES
#=================================================
ynh_script_progression --message="Validating installation parameters..."

# Création des répertoires médias et statiques
mkdir -p "$install_dir/media" "$install_dir/static"

#=================================================
# CONFIGURATION DU LOGGING
#=================================================
ynh_script_progression --message="Setting up logging..."
myynh_setup_log_file
ynh_config_add_logrotate "$log_file"

#=================================================
# INSTALLATION DES DÉPENDANCES
#=================================================
#ynh_script_progression --message="Installing dependencies..."
#ynh_install_depends python3 python3-pip python3-venv postgresql libpq-dev

#=================================================
# CONFIGURATION DE LA BASE DE DONNÉES (POSTGRESQL)
#=================================================
ynh_script_progression --message="Configuring PostgreSQL database..."

# Création de l'utilisateur et de la base de données
sudo -u postgres psql <<EOF
CREATE USER $postgresql_user WITH PASSWORD '$postgresql_pwd';
CREATE DATABASE $postgresql_db OWNER $postgresql_user;
EOF

#=================================================
# CONFIGURATION DU PYTHON VIRTUALENV
#=================================================
ynh_script_progression --message="Creating and setting up Python virtualenv..."

# Copier le script setup_python.py si nécessaire
cp ../conf/setup_python.py "$install_dir/setup_python.py"
chmod +x "$install_dir/setup_python.py"

# Exécuter le script de setup Python
sudo -u $app python3 "$install_dir/setup_python.py"

# Création de l'environnement virtuel
python3 -m venv "$install_dir/venv"
source "$install_dir/venv/bin/activate"

# Mise à jour de pip et installation des dépendances
pip install --upgrade pip setuptools wheel
pip install gunicorn psycopg2 django
pip install git+https://github.com/mpkasp/django-bom.git

#=================================================
# CONFIGURATION DE DJANGO-BOM
#=================================================
ynh_script_progression --message="Configuring Django-Bom..."

# Copier les fichiers de configuration Django
ynh_config_add --template="settings.py" --destination="$install_dir/settings.py"
ynh_config_add --template="wsgi.py" --destination="$install_dir/wsgi.py"

# Exécuter les migrations et collecter les fichiers statiques
cd "$install_dir" || exit
source venv/bin/activate
python manage.py migrate --no-input
python manage.py collectstatic --no-input --clear

# Création d'un superuser
admin_email="$(ynh_user_get_info --username="$admin" --key=mail)"
python manage.py createsuperuser --noinput --username="$admin" --email="$admin_email" || true

#=================================================
# CONFIGURATION DU SERVICE SYSTEMD
#=================================================
ynh_script_progression --message="Configuring systemd service..."

cat > /etc/systemd/system/$app.service <<EOF
[Unit]
Description=Django-Bom Gunicorn
After=network.target postgresql.service

[Service]
User=www-data
Group=www-data
WorkingDirectory=$install_dir
ExecStart=$install_dir/venv/bin/gunicorn --workers 3 --bind unix:$install_dir/gunicorn.sock django_bom.wsgi:application

[Install]
WantedBy=multi-user.target
EOF

# Activer et démarrer le service
systemctl enable $app
systemctl start $app

#=================================================
# CONFIGURATION NGINX
#=================================================
ynh_script_progression --message="Configuring nginx web server..."

cat > "/etc/nginx/conf.d/$domain.d/$app.conf" <<EOF
server {
    listen 80;
    server_name $domain;

    location / {
        proxy_pass http://unix:$install_dir/gunicorn.sock;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
    }
}
EOF

# Redémarrer nginx
systemctl reload nginx

#=================================================
# INTEGRATION AVEC YUNOHOST
#=================================================
ynh_script_progression --message="Integrating service in YunoHost..."

yunohost service add --description "Django-Bom" $app

#=================================================
# SÉCURISATION DES FICHIERS ET PERMISSIONS
#=================================================
ynh_script_progression --message="Setting file permissions..."
myynh_fix_file_permissions

#=================================================
# FINALISATION DE L'INSTALLATION
#=================================================
ynh_script_progression --message="Installation of $app completed" --last
